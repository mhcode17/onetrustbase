# ─────────────────────────────────────────────────────────────
# GetReport environment configuration
# Copy this file to `.env` and fill in the real values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local example: postgresql://postgres:postgres@localhost:5432/getreport?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/getreport?schema=public"

# ── Telegram ──────────────────────────────────────────────────
# From @BotFather: the token of YOUR bot (used both for the bot AND to
# verify the Telegram Login Widget signature on the website).
TELEGRAM_BOT_TOKEN="123456789:AA-your-bot-token-here"

# The bot's username WITHOUT the leading @ (e.g. GetReportBot).
# Needed by the Telegram Login Widget on the website.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="GetReportBot"

# ── Sessions ──────────────────────────────────────────────────
# A long random secret used to sign session cookies (min 32 chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# ── App ───────────────────────────────────────────────────────
# Public base URL of the website (used by the bot to link users to cards
# and by the login widget). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated Telegram numeric user IDs that should be ADMINS on first login.
# Find your ID by messaging @userinfobot on Telegram.
BOOTSTRAP_ADMIN_TELEGRAM_IDS="123456789"
